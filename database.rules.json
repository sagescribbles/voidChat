{
  "rules": {
    "presence": {
      ".read": "auth != null",
      "$roomId": {
        "$uid": {
          ".write": "auth != null && $uid === auth.uid",
          "username": { ".validate": "newData.isString()" },
          "speaking": { ".validate": "newData.isBoolean()" },
          "muted": { ".validate": "newData.isBoolean()" },
          "role": { ".validate": "newData.val() === 'speaker' || newData.val() === 'audience'" },
          "handRaised": { ".validate": "newData.isBoolean()" }
        }
      }
    },
    "signaling": {
      "$roomId": {
        "$uid": {
          ".read": "auth != null && $uid === auth.uid",
          ".write": "auth != null && (newData.child('from').val() === auth.uid || !newData.exists())",
          "$signalId": {
            ".validate": "newData.hasChildren(['from', 'type', 'data'])"
          }
        }
      }
    },
    "chat": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$messageId": {
          ".validate": "newData.hasChildren(['userId', 'username', 'text']) && (newData.child('userId').val() === auth.uid || !newData.exists())"
        }
      }
    },
    "reactions": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$messageId": {
          "userId": { ".validate": "newData.val() === auth.uid" },
          "$emoji": {
             "$uid": {
                ".write": "auth != null && $uid === auth.uid",
                ".validate": "newData.val() === true"
             }
          }
        }
      }
    },
    "flux": {
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null",
        "$logId": {
          ".validate": "newData.hasChildren(['text', 'timestamp'])"
        }
      }
    },
    "typing": {
      "$roomId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && $uid === auth.uid"
        }
      }
    },
    "rooms": {
      "$roomId": {
        ".read": "auth != null",
        "presence": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid"
          }
        },
        "typing": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid"
          }
        },
        "flux": {
          ".read": "auth != null",
          ".write": "auth != null"
        },
        "reactions": {
          ".read": "auth != null",
          ".write": "auth != null"
        }
      }
    },
    ".read": false,
    ".write": false
  }
}